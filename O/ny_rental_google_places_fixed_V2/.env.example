NEXT_PUBLIC_SITE_URL=https://your-production-domain.example
ALLOWED_APP_ORIGINS=https://your-production-domain.example,http://localhost:5503

# Server-only Google APIs. Do not prefix these with NEXT_PUBLIC_.
GOOGLE_PLACES_API_KEY=replace-with-server-only-google-places-key
GOOGLE_SHEET_ID=replace-with-private-google-sheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-service-account-private-key\n-----END PRIVATE KEY-----\n"

# Strong random values are required before launch.
ADMIN_PASSWORD=replace-with-a-strong-random-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes
ADMIN_SYNC_TOKEN=replace-with-at-least-32-random-bytes

# Used by Vercel Cron to authorize the scheduled GET /api/admin/sync.
# Set the SAME value in the Vercel project's Environment Variables.
CRON_SECRET=replace-with-at-least-32-random-bytes

# Keep disabled in Vercel/serverless unless you intentionally accept ephemeral local writes.
ENABLE_LOCAL_DATA_STORE=0
